# Database (use "db" as host when running via docker compose)
DATABASE_URL=postgresql+asyncpg://weather:weather@localhost:5432/weatheredge

# Telegram alerts (leave empty for dry-run mode)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading parameters
MIN_EDGE=0.10
KELLY_FRACTION=0.25
MAX_POSITION_PCT=0.05
INITIAL_BANKROLL=750

# GRIB forecast cache
GEFS_CACHE_DIR=/data/grib_cache/gfs
GEFS_CACHE_TTL_HOURS=24
ECMWF_CACHE_DIR=/data/grib_cache/ecmwf
ECMWF_CACHE_TTL_HOURS=24

# Polymarket execution (leave PRIVATE_KEY empty for dry-run)
POLYMARKET_PRIVATE_KEY=
AUTO_EXECUTE=false
DAILY_SPEND_CAP_USD=200
MIN_STAKE_USD=5

# Short-range pipeline
SR_PIPELINE_INTERVAL_MINUTES=60
